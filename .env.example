# Copia questo file in .env e compila i valori reali
# cp .env.example .env

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# Porcupine wake word — https://console.picovoice.ai
# Lascia vuoto per usare openWakeWord (fallback gratuito)
PORCUPINE_ACCESS_KEY=your_porcupine_key_here
PORCUPINE_MODEL_PATH=./assets/nico_linux.ppn
WAKE_WORD_CUSTOM_MODEL=

# Piper TTS — percorsi locali al binario e alla voce
PIPER_BIN=../nico/piper/piper
PIPER_VOICE=../nico/piper/voices/it_IT-paola-medium.onnx

# Ollama (moondream vision) — default localhost
OLLAMA_BASE_URL=http://localhost:11434

# Audio / STT (valori di default già funzionanti, modifica se necessario)
STT_SILENCE_RMS_THRESHOLD=300
STT_SILENCE_DURATION_S=2.0
STT_MIN_SPEECH_S=0.5

# GPIO Raspberry Pi (BCM pin numbers)
PRIVACY_LED_PIN=17
PRIVACY_BTN_PIN=27
